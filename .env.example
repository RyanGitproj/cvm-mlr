# Supabase Dashboard > Project Settings > API Keys
# URL du projet, par exemple : https://xxxxxxxx.supabase.co
SUPABASE_URL=https://VOTRE_PROJECT_REF.supabase.co

# Clé serveur moderne `sb_secret_...` (jamais de préfixe NEXT_PUBLIC_)
SUPABASE_SECRET_KEY=sb_secret_VOTRE_CLE_SERVEUR

# Secret aléatoire long utilisé pour signer les cookies de relation.
# Exemple de génération PowerShell :
# $bytes = New-Object byte[] 48; [Security.Cryptography.RandomNumberGenerator]::Fill($bytes); [Convert]::ToBase64String($bytes)
LEAD_COOKIE_SECRET=REMPLACEZ_PAR_UN_SECRET_ALEATOIRE_LONG

# Anciennes variables encore acceptées si le projet utilise les clés JWT legacy :
# NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=VOTRE_ANCIENNE_CLE_SERVICE_ROLE
